# Inherits all vars from root .env — only override here if needed

# Python backend port (Express stays on 3001 during parallel testing)
PORT=3002

# ARQ worker Redis DB (separate from BullMQ DB=0 to avoid key collisions)
ARQ_REDIS_URL=redis://localhost:6379/2

# Optional email transport override for backend-py only.
# Example:
# EMAIL_PROVIDER=resend
# EMAIL_FROM_ADDRESS=noreply@yourdomain.com
