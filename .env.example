# Cognitive Copilot — root .env template. Copy to .env and fill in real values.
# NEVER commit a real .env — it's git-ignored for a reason.

# ── Database ─────────────────────────────────────────────────
# Docker compose spins up Postgres with pgvector on port 5432 by default.
POSTGRES_USER=copilot
POSTGRES_PASSWORD=copilot
POSTGRES_DB=copilot_db
DATABASE_URL=postgresql://copilot:copilot@localhost:5432/copilot_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ─────────────────────────────────────────────────────
# Generate a fresh one: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
AUTH_SECRET=replace-me-with-32-byte-random-base64
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Cloudinary (material uploads) ───────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=cognitive-copilot

# ── Ollama (local LLM) ──────────────────────────────────────
# Pull before first run: `ollama pull qwen2.5:7b-instruct && ollama pull nomic-embed-text`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIM=768

# ── Python AI sidecar ───────────────────────────────────────
# docker compose exposes it on port 8000 by default.
AI_SIDECAR_URL=http://localhost:8000

# ── Observability ───────────────────────────────────────────
METRICS_KEY=change-me-if-scraping-externally
LLM_LOG_SAMPLING_RATE=1.0

# ── Feature flags ───────────────────────────────────────────
ENABLE_CROSS_ENCODER=false
ENABLE_AGENT_TOOLS=true

# ── Agent + RAG tuning ──────────────────────────────────────
AGENT_MAX_ITERATIONS=5
AGENT_WALL_CLOCK_MS=12000
RAG_TOP_K=8
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=150

# ── App ─────────────────────────────────────────────────────
PORT=3001
CORS_ORIGINS=http://localhost:5173
NODE_ENV=development

# ── Email (SMTP, optional) ──────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cognitivecopilot.com
SMTP_USE_TLS=true
FRONTEND_URL=http://localhost:5173

# ── Google Classroom OAuth (optional) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/google-classroom/callback

# ── Production domain (used by Caddy in the "prod" compose profile) ──
DOMAIN=localhost
